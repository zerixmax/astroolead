---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Slideshow from '../components/Slideshow.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="OLEA - Digitalna trasabilnost maslinovog ulja">
	<Header />
	
	<main>
		<Slideshow />
		
		<section class="py-32 px-6">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-4xl md:text-6xl font-serif mb-8 leading-tight">
					Platforma za digitalnu trasabilnost maslinovog ulja.
				</h1>
				<p class="text-xl md:text-2xl text-olea-olive font-medium">
					Od stabla do boce — s digitalnim certifikatom autentičnosti.
				</p>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
