---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Slideshow from '../components/Slideshow.astro';
import Footer from '../components/Footer.astro';
import content from '../data/content.json';

// Uvoz pozadine za OleaDbot sekciju
import botBg from '../assets/images/olead-bot-plan.webp';
---

<Layout 
  title={content.seo.title} 
  description={content.seo.description}
  keywords={content.seo.keywords}
>
  <Header />
  
  <main>
    <section class="max-w-6xl mx-auto py-12 px-6">
      <Slideshow />
    </section>
    
    <section class="py-32 px-6 border-t border-olea-olive/10">
      <div class="max-w-4xl mx-auto text-center space-y-10">
        <h1 class="text-4xl md:text-6xl font-serif text-olea-earth leading-tight italic">
          {content.hero.title}
        </h1>
        <div class="flex flex-col items-center gap-6">
          <div class="h-px w-24 bg-olea-olive/30"></div>
          <p class="text-xl md:text-3xl font-sans text-olea-olive tracking-widest uppercase italic font-light">
            {content.hero.subtitle}
          </p>
          <div class="h-px w-24 bg-olea-olive/30"></div>
        </div>
      </div>
    </section>

    <section id="projekt" class="py-32 px-6 bg-white border-t border-olea-olive/5">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-serif text-olea-earth mb-8">{content.sections.projekt.title}</h2>
        <p class="text-xl text-olea-earth/80 leading-relaxed max-w-2xl mx-auto font-sans">
          {content.sections.projekt.description}
        </p>
      </div>
    </section>

    <section id="oleadbot" class="relative py-32 px-6 bg-olea-sand border-t border-olea-olive/5 overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-10 pointer-events-none">
        <Image src={botBg} alt="" class="w-full h-full object-cover" />
      </div>
      
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-serif text-olea-earth mb-8">{content.sections.oleadbot.title}</h2>
        <p class="text-xl text-olea-earth/80 leading-relaxed max-w-2xl mx-auto font-sans">
          {content.sections.oleadbot.description}
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
