---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Slideshow from '../components/Slideshow.astro';
import Footer from '../components/Footer.astro';
import content from '../data/content.json';

// Uvoz slika
import heroBg from '../assets/images/olive-hero-bg.webp';
import botBg from '../assets/images/olead-bot-plan.webp';
import nodeBg from '../assets/images/olead-otok-mapa.webp';
---

<Layout 
  title={content.seo.title} 
  description={content.seo.description}
  keywords={content.seo.keywords}
>
  <Header />
  
  <main>
    <section class="max-w-6xl mx-auto py-12 px-6">
      <Slideshow />
    </section>
    
    <section class="relative py-32 px-6 bg-olea-sand overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-10 pointer-events-none">
        <Image src={heroBg} alt="" class="w-full h-full object-cover" />
      </div>
      <div class="relative z-10 max-w-4xl mx-auto text-center space-y-10">
        <h1 class="text-4xl md:text-6xl font-serif text-olea-earth leading-tight italic">{content.hero.title}</h1>
        <p class="text-xl md:text-3xl font-sans text-olea-olive tracking-widest uppercase italic">{content.hero.subtitle}</p>
      </div>
    </section>

    <section id="oleadbot" class="relative py-64 px-6 bg-olea-sand border-t border-olea-olive/5 overflow-hidden flex items-center">
      <div class="absolute inset-0 z-0 opacity-15 pointer-events-none">
        <Image src={botBg} alt="" class="w-full h-full object-cover" />
      </div>
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-serif mb-8">{content.sections.oleadbot.title}</h2>
        <p class="text-xl md:text-2xl bg-olea-sand/60 backdrop-blur-sm p-6 rounded-lg">{content.sections.oleadbot.description}</p>
      </div>
    </section>

    <section id="oleadnode" class="relative py-48 px-6 bg-white border-t border-olea-olive/5 overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-10 pointer-events-none">
        <Image src={nodeBg} alt="" class="w-full h-full object-cover" />
      </div>
      <div class="relative z-10 max-w-4xl mx-auto text-center text-olea-earth">
        <h2 class="text-4xl font-serif mb-8">{content.sections.oleadnode.title}</h2>
        <p class="text-xl bg-white/60 backdrop-blur-sm p-6 rounded-lg">{content.sections.oleadnode.description}</p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
