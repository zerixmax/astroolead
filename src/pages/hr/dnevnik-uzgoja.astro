---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'hr';
const t = useTranslations(lang);
---

<Layout title={t('seo.dnevnikTitle')} lang={lang}>
  <Navbar lang={lang} />

  <main
    class="mx-auto flex min-h-[60vh] max-w-4xl flex-col justify-center px-6 py-24 text-center"
  >
    <h1 class="text-olea-earth mb-6 font-serif text-5xl">
      {t('dnevnik.naslov')}
    </h1>
    <p class="text-olea-earth/80 mb-12 font-sans text-xl leading-relaxed">
      {t('dnevnik.opis')}
    </p>

    <h2 class="text-olea-earth mb-8 font-serif text-3xl">
      {t('dnevnik.funkcionalnosti')}
    </h2>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div
        class="border-olea-olive/10 rounded-2xl border bg-white p-6 shadow-sm"
      >
        <h3 class="text-olea-earth mb-3 text-xl font-bold">
          {t('dnevnik.f1_title')}
        </h3>
        <p class="text-olea-earth/70">{t('dnevnik.f1_desc')}</p>
      </div>
      <div
        class="border-olea-olive/10 rounded-2xl border bg-white p-6 shadow-sm"
      >
        <h3 class="text-olea-earth mb-3 text-xl font-bold">
          {t('dnevnik.f2_title')}
        </h3>
        <p class="text-olea-earth/70">{t('dnevnik.f2_desc')}</p>
      </div>
      <div
        class="border-olea-olive/10 rounded-2xl border bg-white p-6 shadow-sm"
      >
        <h3 class="text-olea-earth mb-3 text-xl font-bold">
          {t('dnevnik.f3_title')}
        </h3>
        <p class="text-olea-earth/70">{t('dnevnik.f3_desc')}</p>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
