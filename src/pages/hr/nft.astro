---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { useTranslations, ui } from '../../i18n/ui';

import qrImage from '../../assets/images/qr-nft-vl01-t001.webp';

const lang = 'hr';
const t = useTranslations(lang);
const content = ui[lang].certifikati;
---

<Layout title={`${t('nav.certifikati')} | Olea Digitalis`} lang={lang}>
  <Navbar lang={lang} />

  <main class="bg-olea-sand text-olea-earth min-h-screen px-6 py-24 md:px-12">
    <div class="mx-auto max-w-5xl space-y-16">
      <!-- Page Header -->
      <div class="mx-auto max-w-3xl space-y-6 text-center">
        <h1
          class="text-olea-olive font-serif text-5xl font-extrabold tracking-wide"
        >
          {content.naslov}
        </h1>
        <p class="text-olea-earth/80 font-sans text-xl leading-relaxed">
          {content.opis}
        </p>
      </div>

      <!-- Featured Proof of Concept QR -->
      <div
        class="border-olea-olive/15 mx-auto flex max-w-xl flex-col items-center justify-center space-y-6 rounded-3xl border bg-white p-8 text-center shadow-sm"
      >
        <h2 class="text-olea-olive font-serif text-2xl font-bold">
          {content.prvi_nft}
        </h2>
        <div
          class="border-olea-olive rounded-2xl border-4 bg-white p-2 shadow-md"
        >
          <Image src={qrImage} alt="QR Code VL01-T001" class="h-48 w-48" />
        </div>
        <p class="text-olea-earth/80 font-sans text-sm leading-relaxed">
          {ui[lang].o_projektu.poc}
        </p>
        <span
          class="bg-olea-olive/10 text-olea-olive border-olea-olive/20 rounded-full border px-3 py-1 font-mono text-xs"
        >
          Asset ID: #VL01-T001
        </span>
      </div>

      <!-- Live Ledger/History Placeholder (Premium Card Layout) -->
      <div
        class="border-olea-olive/15 space-y-8 rounded-3xl border bg-white p-8 shadow-sm md:p-12"
      >
        <div
          class="border-olea-olive/10 flex flex-col items-start justify-between gap-4 border-b pb-6 md:flex-row md:items-center"
        >
          <div>
            <h2 class="text-olea-olive font-serif text-2xl font-bold">
              {content.registar_aktivnih}
            </h2>
            <p class="text-olea-earth/70 font-sans text-sm">
              {content.simulacija}
            </p>
          </div>
          <div
            class="bg-olea-olive/10 text-olea-olive border-olea-olive/20 flex animate-pulse items-center gap-2 rounded-full border px-3 py-1.5 font-mono text-xs"
          >
            <span class="bg-olea-olive h-2.5 w-2.5 rounded-full"></span>
            <span>{content.mreza_aktivna}</span>
          </div>
        </div>

        <!-- Simulated Certification Records -->
        <div class="space-y-6">
          <div
            class="border-olea-olive/10 hover:bg-olea-sand/30 rounded-2xl border p-6 transition-all"
          >
            <div
              class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-center"
            >
              <div class="space-y-2">
                <div class="flex items-center gap-3">
                  <span
                    class="bg-olea-olive rounded px-2 py-0.5 font-mono text-xs text-white"
                    >Asset ID: #VL01-T001</span
                  >
                  <span
                    class="text-olea-earth/60 font-sans text-xs font-semibold"
                    >Algorand Blockchain</span
                  >
                </div>
                <h3 class="text-olea-olive font-serif text-xl font-bold">
                  Maslina 001 (OPG Cetinić)
                </h3>
                <p class="text-olea-earth/80 font-sans text-sm">
                  {content.opis_001}
                </p>
              </div>
              <div class="flex flex-col gap-2 md:items-end">
                <span class="text-olea-earth/60 font-mono text-xs"
                  >0x5958...38527</span
                >
                <span
                  class="text-olea-olive bg-olea-olive/5 border-olea-olive/15 rounded border px-3 py-1 font-mono text-xs font-bold"
                >
                  {content.potvrdjeno}
                </span>
              </div>
            </div>
          </div>

          <div
            class="border-olea-olive/10 hover:bg-olea-sand/30 rounded-2xl border p-6 opacity-80 transition-all"
          >
            <div
              class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-center"
            >
              <div class="space-y-2">
                <div class="flex items-center gap-3">
                  <span
                    class="bg-olea-olive/40 text-olea-earth rounded px-2 py-0.5 font-mono text-xs"
                    >Asset ID: #VL01-T002</span
                  >
                  <span
                    class="text-olea-earth/60 font-sans text-xs font-semibold"
                    >Algorand Blockchain</span
                  >
                </div>
                <h3 class="text-olea-olive font-serif text-xl font-bold">
                  Maslina 002 (OPG Cetinić)
                </h3>
                <p class="text-olea-earth/80 font-sans text-sm">
                  {content.opis_002}
                </p>
              </div>
              <div class="flex flex-col gap-2 md:items-end">
                <span class="text-olea-earth/60 font-mono text-xs"
                  >0x5166...17877</span
                >
                <span
                  class="text-olea-olive bg-olea-olive/5 border-olea-olive/15 rounded border px-3 py-1 font-mono text-xs font-bold"
                >
                  {content.potvrdjeno}
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- Info/Callout Box -->
        <div
          class="bg-olea-olive/5 border-olea-olive/10 space-y-3 rounded-2xl border p-6 text-center"
        >
          <p
            class="text-olea-earth/80 mx-auto max-w-2xl font-sans text-sm leading-relaxed"
          >
            {content.info_callout}
          </p>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
