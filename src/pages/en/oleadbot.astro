---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout title={t('seo.oleadbotTitle')} lang={lang}>
  <Navbar lang={lang} />
  <main class="mx-auto min-h-[80vh] max-w-5xl px-6 py-24">
    <!-- Hero / Intro -->
    <div
      class="scroll-reveal animate-fade-in-up mx-auto mb-16 max-w-4xl text-center"
    >
      <span
        class="bg-olea-olive/10 text-olea-olive border-olea-olive/20 mb-6 inline-block rounded-full border px-4 py-2 font-mono text-xs tracking-widest uppercase"
      >
        Robotic Assistant
      </span>
      <h1
        class="text-olea-earth mb-6 font-serif text-4xl leading-tight font-semibold md:text-5xl"
      >
        {t('sections.oleadbot.title')}
      </h1>
      <p
        class="text-olea-earth/80 font-sans text-lg leading-relaxed md:text-xl"
      >
        {t('sections.oleadbot.description')}
      </p>
    </div>

    <!-- Phases Section -->
    <div class="scroll-reveal mb-16 grid grid-cols-1 gap-8 md:grid-cols-2">
      <!-- Phase 1 -->
      <div
        class="border-olea-olive/10 group relative flex flex-col justify-between overflow-hidden rounded-2xl border bg-white/50 p-8 shadow-md backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
      >
        <div>
          <div class="mb-6 flex items-center justify-between">
            <div
              class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-600 transition-transform group-hover:scale-110"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
                ></path>
              </svg>
            </div>
            <span
              class="rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 font-mono text-xs font-bold tracking-wider text-emerald-600 uppercase"
            >
              TRL 6 - Ready and tested
            </span>
          </div>
          <h3
            class="text-olea-earth mb-4 font-serif text-2xl leading-snug font-bold"
          >
            {t('sections.oleadbot.f1_title')}
          </h3>
          <p
            class="text-olea-earth/70 mb-6 font-sans text-sm leading-relaxed md:text-base"
          >
            {t('sections.oleadbot.f1_desc')}
          </p>
        </div>
        <div
          class="border-olea-olive/10 text-olea-olive flex items-center gap-2 border-t pt-4 font-mono text-xs"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 animate-pulse"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          Wireless data retrieval and RTK GPS integration
        </div>
      </div>

      <!-- Phase 2 -->
      <div
        class="border-olea-olive/10 group relative flex flex-col justify-between overflow-hidden rounded-2xl border bg-white/50 p-8 shadow-md backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
      >
        <div>
          <div class="mb-6 flex items-center justify-between">
            <div
              class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10 text-blue-600 transition-transform group-hover:scale-110"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"
                ></path>
              </svg>
            </div>
            <span
              class="rounded-full border border-blue-500/20 bg-blue-500/10 px-3 py-1 font-mono text-xs font-bold tracking-wider text-blue-600 uppercase"
            >
              In development - Conceptual phase
            </span>
          </div>
          <h3
            class="text-olea-earth mb-4 font-serif text-2xl leading-snug font-bold"
          >
            {t('sections.oleadbot.f2_title')}
          </h3>
          <p
            class="text-olea-earth/70 mb-6 font-sans text-sm leading-relaxed md:text-base"
          >
            {t('sections.oleadbot.f2_desc')}
          </p>
        </div>
        <div
          class="border-olea-olive/10 flex items-center gap-2 border-t pt-4 font-mono text-xs text-blue-600"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
            ></path>
          </svg>
          Autonomous movement and payload transport
        </div>
      </div>
    </div>
  </main>
  <Footer lang={lang} />
</Layout>
