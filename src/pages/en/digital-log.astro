---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout title={t('seo.dnevnikTitle')} lang={lang}>
  <Navbar lang={lang} />
  
  <main class="max-w-4xl mx-auto py-24 px-6 min-h-[60vh] flex flex-col justify-center text-center">
    <h1 class="text-5xl font-serif text-olea-earth mb-6">{t('dnevnik.naslov')}</h1>
    <p class="text-xl text-olea-earth/80 leading-relaxed font-sans mb-12">{t('dnevnik.opis')}</p>
    
    <h2 class="text-3xl font-serif text-olea-earth mb-8">{t('dnevnik.funkcionalnosti')}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-white p-6 rounded-2xl shadow-sm border border-olea-olive/10">
        <h3 class="text-xl font-bold text-olea-earth mb-3">{t('dnevnik.f1_title')}</h3>
        <p class="text-olea-earth/70">{t('dnevnik.f1_desc')}</p>
      </div>
      <div class="bg-white p-6 rounded-2xl shadow-sm border border-olea-olive/10">
        <h3 class="text-xl font-bold text-olea-earth mb-3">{t('dnevnik.f2_title')}</h3>
        <p class="text-olea-earth/70">{t('dnevnik.f2_desc')}</p>
      </div>
      <div class="bg-white p-6 rounded-2xl shadow-sm border border-olea-olive/10">
        <h3 class="text-xl font-bold text-olea-earth mb-3">{t('dnevnik.f3_title')}</h3>
        <p class="text-olea-earth/70">{t('dnevnik.f3_desc')}</p>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
