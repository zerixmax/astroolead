---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout title={t('seo.oleadnodeTitle')} lang={lang}>
  <Navbar lang={lang} />
  <main class="mx-auto min-h-[80vh] max-w-5xl px-6 py-24">
    <!-- Hero / Intro -->
    <div
      class="scroll-reveal animate-fade-in-up mx-auto mb-16 max-w-4xl text-center"
    >
      <span
        class="bg-olea-olive/10 text-olea-olive border-olea-olive/20 mb-6 inline-block rounded-full border px-4 py-2 font-mono text-xs tracking-widest uppercase"
      >
        IoT Sensor Station
      </span>
      <h1
        class="text-olea-earth mb-6 font-serif text-4xl leading-tight font-semibold md:text-5xl"
      >
        {t('sections.oleadnode.title')}
      </h1>
      <p
        class="text-olea-earth/80 font-sans text-lg leading-relaxed md:text-xl"
      >
        {t('sections.oleadnode.description')}
      </p>
    </div>

    <!-- Development Journey Section -->
    <div class="scroll-reveal mb-20">
      <h2
        class="text-olea-earth mb-10 text-center font-serif text-2xl md:text-3xl"
      >
        {t('sections.oleadnode.put_naslov')}
      </h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        <!-- Step 1 -->
        <div
          class="border-olea-olive/10 group relative overflow-hidden rounded-2xl border bg-white/50 p-8 shadow-md backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
        >
          <div
            class="bg-olea-olive/5 absolute top-0 right-0 -z-10 h-24 w-24 rounded-bl-full transition-transform group-hover:scale-110"
          >
          </div>
          <div
            class="bg-olea-olive/10 text-olea-olive mb-6 flex h-12 w-12 items-center justify-center rounded-xl transition-transform group-hover:scale-110"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"
              ></path>
            </svg>
          </div>
          <div class="mb-3 flex items-center gap-2">
            <span
              class="rounded bg-emerald-500/10 px-2.5 py-1 font-mono text-[10px] font-bold tracking-wider text-emerald-600 uppercase"
            >
              Completed
            </span>
          </div>
          <h3 class="text-olea-earth mb-3 font-serif text-xl font-bold">
            {t('sections.oleadnode.t1_title')}
          </h3>
          <p
            class="text-olea-earth/70 font-sans text-sm leading-relaxed md:text-base"
          >
            {t('sections.oleadnode.t1_desc')}
          </p>
        </div>

        <!-- Step 2 -->
        <div
          class="border-olea-olive/10 group relative overflow-hidden rounded-2xl border bg-white/50 p-8 shadow-md backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
        >
          <div
            class="absolute top-0 right-0 -z-10 h-24 w-24 rounded-bl-full bg-amber-500/5 transition-transform group-hover:scale-110"
          >
          </div>
          <div
            class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10 text-amber-600 transition-transform group-hover:scale-110"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
              ></path>
            </svg>
          </div>
          <div class="mb-3 flex items-center gap-2">
            <span
              class="rounded bg-amber-500/10 px-2.5 py-1 font-mono text-[10px] font-bold tracking-wider text-amber-600 uppercase"
            >
              In preparation
            </span>
          </div>
          <h3 class="text-olea-earth mb-3 font-serif text-xl font-bold">
            {t('sections.oleadnode.t2_title')}
          </h3>
          <p
            class="text-olea-earth/70 font-sans text-sm leading-relaxed md:text-base"
          >
            {t('sections.oleadnode.t2_desc')}
          </p>
        </div>

        <!-- Step 3 -->
        <div
          class="border-olea-olive/10 group relative overflow-hidden rounded-2xl border bg-white/50 p-8 shadow-md backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
        >
          <div
            class="absolute top-0 right-0 -z-10 h-24 w-24 rounded-bl-full bg-blue-500/5 transition-transform group-hover:scale-110"
          >
          </div>
          <div
            class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10 text-blue-600 transition-transform group-hover:scale-110"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <div class="mb-3 flex items-center gap-2">
            <span
              class="rounded bg-blue-500/10 px-2.5 py-1 font-mono text-[10px] font-bold tracking-wider text-blue-600 uppercase"
            >
              Planned
            </span>
          </div>
          <h3 class="text-olea-earth mb-3 font-serif text-xl font-bold">
            {t('sections.oleadnode.t3_title')}
          </h3>
          <p
            class="text-olea-earth/70 font-sans text-sm leading-relaxed md:text-base"
          >
            {t('sections.oleadnode.t3_desc')}
          </p>
        </div>
      </div>
    </div>
  </main>
  <Footer lang={lang} />
</Layout>
