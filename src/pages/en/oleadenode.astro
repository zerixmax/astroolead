---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout title={t('seo.oleadnodeTitle')} lang={lang}>
  <Navbar lang={lang} />
  <main
    class="mx-auto flex min-h-[60vh] max-w-4xl flex-col justify-center px-6 py-24 text-center"
  >
    <h1 class="text-olea-earth mb-6 font-serif text-5xl">
      {t('sections.oleadnode.title')}
    </h1>
    <p class="text-olea-earth/80 font-sans text-xl leading-relaxed">
      {t('sections.oleadnode.description')}
    </p>
  </main>
  <Footer lang={lang} />
</Layout>
