---
import { routes } from '../i18n/routes';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  lang?: string;
}

const {
  title,
  description = 'Digitalna sljedivost maslinovog ulja.',
  keywords = 'maslinovo ulje, sljedivost, OPG',
  lang = 'hr',
} = Astro.props;

import '../styles/global.css';

const canonicalUrl = new URL(
  Astro.url.pathname,
  'https://oleadigitalis.eu'
).toString();

// Generate dynamic language alternate URLs for the current page using the routes dictionary
const pathname = Astro.url.pathname;
const segments = pathname.split('/').filter(Boolean);

let currentSlug = '';
if (segments.length > 1) {
  currentSlug = segments[1];
}

let routeKey: keyof typeof routes.hr | null = null;
if (currentSlug) {
  const currentLocale = lang as 'hr' | 'en';
  const entries = Object.entries(routes[currentLocale]) as [
    keyof typeof routes.hr,
    string,
  ][];
  const found = entries.find((entry) => entry[1] === currentSlug);
  if (found) {
    routeKey = found[0];
  }
}

let hrPath = '/hr/';
let enPath = '/en/';

if (routeKey) {
  hrPath = `/hr/${routes.hr[routeKey]}/`;
  enPath = `/en/${routes.en[routeKey]}/`;
}

const hrUrl = new URL(hrPath, 'https://oleadigitalis.eu').toString();
const enUrl = new URL(enPath, 'https://oleadigitalis.eu').toString();
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Olea Digitalis" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang alternates for Multilingual SEO -->
    <link rel="alternate" hreflang="hr" href={hrUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={hrUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Olea Digitalis" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body
    class="bg-olea-sand text-olea-earth flex min-h-screen flex-col font-sans antialiased"
  >
    <slot />

    <!-- Back to Top Button -->
    <button
      id="back-to-top"
      class="border-olea-olive/20 text-olea-olive hover:bg-olea-olive pointer-events-none fixed right-6 bottom-28 z-50 flex h-12 w-12 translate-y-16 cursor-pointer items-center justify-center rounded-full border bg-white/80 opacity-0 shadow-lg backdrop-blur-sm transition-all duration-500 hover:scale-110 hover:text-white active:scale-95"
      aria-label="Back to top"
    >
      <span class="animate-float">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"
          ></path>
        </svg>
      </span>
    </button>

    <script>
      function initScrollReveal() {
        // Native check: if browser supports CSS scroll-driven animations, exit and let CSS handle it.
        if (
          CSS.supports(
            '(animation-timeline: view()) and (animation-range: entry)'
          )
        ) {
          return;
        }

        // JS Fallback for other browsers (like Firefox or older versions)
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                // Unobserve to run the animation only once
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.1, // Trigger when 10% of the element is visible
            rootMargin: '0px 0px -40px 0px', // Slight offset for more natural feel
          }
        );

        document.querySelectorAll('.scroll-reveal').forEach((el) => {
          observer.observe(el);
        });
      }

      // Keep track of scroll listener to prevent duplicate binding
      let scrollListenerActive = false;

      function initBackToTop() {
        const btn = document.getElementById('back-to-top');
        if (!btn) return;

        const toggleVisibility = () => {
          if (window.scrollY > 300) {
            btn.classList.add('show-btn');
          } else {
            btn.classList.remove('show-btn');
          }
        };

        // Scroll to top on click
        btn.addEventListener('click', () => {
          window.scrollTo({
            top: 0,
            behavior: 'smooth',
          });
        });

        // Run initial check
        toggleVisibility();

        if (!scrollListenerActive) {
          window.addEventListener('scroll', () => {
            const activeBtn = document.getElementById('back-to-top');
            if (activeBtn) {
              if (window.scrollY > 300) {
                activeBtn.classList.add('show-btn');
              } else {
                activeBtn.classList.remove('show-btn');
              }
            }
          });
          scrollListenerActive = true;
        }
      }

      // Run on initial load and on Astro View Transitions navigation
      document.addEventListener('DOMContentLoaded', () => {
        initScrollReveal();
        initBackToTop();
      });
      document.addEventListener('astro:page-load', () => {
        initScrollReveal();
        initBackToTop();
      });
    </script>
  </body>
</html>
