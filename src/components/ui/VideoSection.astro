---
import { useTranslations } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const videoId = t('hero.videoId');
---

<section class="bg-white py-24 px-6 border-b border-olea-olive/5">
  <div class="max-w-4xl mx-auto flex flex-col items-center space-y-8">
    
    <!-- Responsive 16:9 Video Container -->
    <div class="w-full aspect-video rounded-2xl shadow-2xl overflow-hidden border border-olea-olive/10 bg-black">
      <iframe 
        class="w-full h-full"
        src={`https://www.youtube.com/embed/${videoId}?rel=0`} 
        title={t('hero.videoSectionTitle')}
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        allowfullscreen
      >
      </iframe>
    </div>

    <!-- Video Title Below Player -->
    <div class="text-center">
      <h2 class="text-3xl font-serif text-olea-earth tracking-wide">
        {t('hero.videoSectionTitle')}
      </h2>
      <div class="h-0.5 w-16 bg-olea-olive/35 mx-auto mt-4"></div>
    </div>

  </div>
</section>
