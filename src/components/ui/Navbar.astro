---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { getRelativeLocaleUrl } from 'astro:i18n';
import logo from '../../assets/images/oleadigitalis_logo264.png';
import { useTranslations } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';
import { routes } from '../../i18n/routes';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Generate dynamic language alternate URLs for the current page using the routes dictionary
const pathname = Astro.url.pathname;
const segments = pathname.split('/').filter(Boolean);

let currentSlug = '';
if (segments.length > 1) {
  currentSlug = segments[1];
}

let routeKey: keyof typeof routes.hr | null = null;
if (currentSlug) {
  const currentLocale = lang;
  const entries = Object.entries(routes[currentLocale]) as [
    keyof typeof routes.hr,
    string,
  ][];
  const found = entries.find((entry) => entry[1] === currentSlug);
  if (found) {
    routeKey = found[0];
  }
}

let hrUrl = '/hr/';
let enUrl = '/en/';

if (routeKey) {
  hrUrl = `/hr/${routes.hr[routeKey]}/`;
  enUrl = `/en/${routes.en[routeKey]}/`;
}
---

<header
  class="bg-olea-sand/90 border-olea-olive/10 sticky top-0 z-50 border-b px-6 py-4 backdrop-blur-md transition-all duration-300 lg:px-12"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between">
    <!-- Logo & Branding -->
    <!-- Logo & Branding -->
    <a
      href={getRelativeLocaleUrl(lang, '')}
      class="flex flex-shrink-0 cursor-pointer items-center gap-3 transition-transform duration-300 hover:scale-105"
    >
      <Image
        src={logo}
        alt="Olea Digitalis Logo"
        width={110}
        class="h-10 w-auto"
      />
      <span class="text-olea-earth font-serif text-lg font-bold"
        >Olea Digitalis</span
      >
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden items-center gap-8 font-serif text-lg md:flex">
      <a
        href={getRelativeLocaleUrl(lang, '')}
        class="hover:text-olea-olive transition-colors duration-200"
        >{t('nav.pocetna')}</a
      >

      <!-- Dropdown O projektu -->
      <div class="group relative">
        <button
          id="desktop-o-projektu-btn"
          class="hover:text-olea-olive flex cursor-pointer items-center gap-1 transition-colors duration-200 focus:outline-none"
          aria-haspopup="true"
          aria-expanded="false"
        >
          {t('nav.oProjektu')}
          <Icon
            name="lucide:chevron-down"
            class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180"
          />
        </button>
        <div
          class="pointer-events-none absolute top-full left-0 z-50 -mt-4 w-48 origin-top-left scale-95 transform pt-4 opacity-0 transition-all duration-200 group-hover:pointer-events-auto group-hover:scale-100 group-hover:opacity-100"
        >
          <div
            class="border-olea-olive/10 mt-2 rounded-xl border bg-white py-2 shadow-xl"
          >
            <a
              href={getRelativeLocaleUrl(lang, routes[lang]['o-projektu'])}
              class="text-olea-earth hover:bg-olea-sand hover:text-olea-olive block px-4 py-2 text-sm transition-colors"
            >
              {t('nav.oProjektu')}
            </a>
            <a
              href={getRelativeLocaleUrl(lang, 'nft')}
              class="text-olea-earth hover:bg-olea-sand hover:text-olea-olive block px-4 py-2 text-sm transition-colors"
            >
              {t('nav.certifikati')}
            </a>
            <a
              href={getRelativeLocaleUrl(lang, 'blog')}
              class="text-olea-earth hover:bg-olea-sand hover:text-olea-olive block px-4 py-2 text-sm transition-colors"
            >
              {t('nav.blog')}
            </a>
          </div>
        </div>
      </div>

      <!-- Dropdown Rješenja -->
      <div class="group relative">
        <button
          id="desktop-dropdown-btn"
          class="hover:text-olea-olive flex cursor-pointer items-center gap-1 transition-colors duration-200 focus:outline-none"
          aria-haspopup="true"
          aria-expanded="false"
        >
          {t('nav.rjesenja')}
          <Icon
            name="lucide:chevron-down"
            class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180"
          />
        </button>
        <div
          class="pointer-events-none absolute top-full left-0 z-50 -mt-4 w-48 origin-top-left scale-95 transform pt-4 opacity-0 transition-all duration-200 group-hover:pointer-events-auto group-hover:scale-100 group-hover:opacity-100"
        >
          <div
            class="border-olea-olive/10 mt-2 rounded-xl border bg-white py-2 shadow-xl"
          >
            <a
              href={getRelativeLocaleUrl(lang, routes[lang]['dnevnik-uzgoja'])}
              class="text-olea-earth hover:bg-olea-sand hover:text-olea-olive block px-4 py-2 text-sm transition-colors"
            >
              {t('nav.dnevnik')}
            </a>
            <a
              href={getRelativeLocaleUrl(lang, 'oleadenode')}
              class="text-olea-earth hover:bg-olea-sand hover:text-olea-olive block px-4 py-2 text-sm transition-colors"
            >
              {t('nav.oleadnode')}
            </a>
            <a
              href={getRelativeLocaleUrl(lang, 'oleadbot')}
              class="text-olea-earth hover:bg-olea-sand hover:text-olea-olive block px-4 py-2 text-sm transition-colors"
            >
              {t('nav.oleadbot')}
            </a>
          </div>
        </div>
      </div>

      <a
        href={`${getRelativeLocaleUrl(lang, '')}#kontakt`}
        class="bg-olea-olive hover:bg-olea-earth rounded-full px-6 py-2 text-white shadow-md transition-all duration-300 hover:shadow-lg"
      >
        {t('nav.kontakt')}
      </a>

      <!-- Language Switcher Desktop -->
      <div
        class="border-olea-olive/20 flex items-center gap-2 border-l pl-6 font-mono text-sm"
      >
        <Icon name="lucide:globe" class="text-olea-olive/75 h-4 w-4" />
        <a
          href={hrUrl}
          class={lang === 'hr'
            ? 'text-olea-olive font-bold'
            : 'hover:text-olea-olive transition-colors opacity-70'}>HR</a
        >
        <span class="opacity-30">|</span>
        <a
          href={enUrl}
          class={lang === 'en'
            ? 'text-olea-olive font-bold'
            : 'hover:text-olea-olive transition-colors opacity-70'}>EN</a
        >
      </div>
    </nav>

    <!-- Mobile Controls (Hamburger only) -->
    <div class="flex items-center gap-4 md:hidden">
      <button
        id="menu-toggle-btn"
        class="text-olea-earth cursor-pointer p-2 focus:outline-none"
        aria-label="Otvori izbornik"
        aria-expanded="false"
      >
        <Icon id="icon-menu-open" name="lucide:menu" class="h-8 w-8" />
        <Icon id="icon-menu-close" name="lucide:x" class="hidden h-8 w-8" />
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="bg-olea-sand border-olea-olive/10 absolute top-full left-0 z-40 hidden w-full flex-col items-center gap-5 border-b py-6 font-serif text-xl shadow-xl transition-all duration-300 md:hidden"
  >
    <a
      href={getRelativeLocaleUrl(lang, '')}
      class="mobile-link hover:text-olea-olive transition-colors"
      >{t('nav.pocetna')}</a
    >

    <!-- Mobile Dropdown O projektu -->
    <div class="flex w-full flex-col items-center">
      <button
        id="mobile-o-projektu-btn"
        class="hover:text-olea-olive flex cursor-pointer items-center gap-1 transition-colors focus:outline-none"
        aria-expanded="false"
      >
        {t('nav.oProjektu')}
        <Icon
          id="mobile-o-projektu-chevron"
          name="lucide:chevron-down"
          class="h-5 w-5 transition-transform duration-300"
        />
      </button>
      <div
        id="mobile-o-projektu-content"
        class="bg-olea-olive/5 border-olea-olive/5 mt-2 hidden w-full flex-col items-center gap-3 border-y py-3 text-lg"
      >
        <a
          href={getRelativeLocaleUrl(lang, routes[lang]['o-projektu'])}
          class="mobile-link text-olea-earth hover:text-olea-olive transition-colors"
        >
          {t('nav.oProjektu')}
        </a>
        <a
          href={getRelativeLocaleUrl(lang, 'nft')}
          class="mobile-link text-olea-earth hover:text-olea-olive transition-colors"
        >
          {t('nav.certifikati')}
        </a>
        <a
          href={getRelativeLocaleUrl(lang, 'blog')}
          class="mobile-link text-olea-earth hover:text-olea-olive transition-colors"
        >
          {t('nav.blog')}
        </a>
      </div>
    </div>

    <!-- Mobile Dropdown Rješenja -->
    <div class="flex w-full flex-col items-center">
      <button
        id="mobile-rjesenja-btn"
        class="hover:text-olea-olive flex cursor-pointer items-center gap-1 transition-colors focus:outline-none"
        aria-expanded="false"
      >
        {t('nav.rjesenja')}
        <Icon
          id="mobile-rjesenja-chevron"
          name="lucide:chevron-down"
          class="h-5 w-5 transition-transform duration-300"
        />
      </button>
      <div
        id="mobile-rjesenja-content"
        class="bg-olea-olive/5 border-olea-olive/5 mt-2 hidden w-full flex-col items-center gap-3 border-y py-3 text-lg"
      >
        <a
          href={getRelativeLocaleUrl(lang, routes[lang]['dnevnik-uzgoja'])}
          class="mobile-link text-olea-earth hover:text-olea-olive transition-colors"
        >
          {t('nav.dnevnik')}
        </a>
        <a
          href={getRelativeLocaleUrl(lang, 'oleadenode')}
          class="mobile-link text-olea-earth hover:text-olea-olive transition-colors"
        >
          {t('nav.oleadnode')}
        </a>
        <a
          href={getRelativeLocaleUrl(lang, 'oleadbot')}
          class="mobile-link text-olea-earth hover:text-olea-olive transition-colors"
        >
          {t('nav.oleadbot')}
        </a>
      </div>
    </div>

    <a
      href={`${getRelativeLocaleUrl(lang, '')}#kontakt`}
      class="mobile-link bg-olea-olive rounded-full px-8 py-2 font-bold text-white shadow-md"
    >
      {t('nav.kontakt')}
    </a>

    <!-- Mobile Language Switcher at the bottom for thumb reachability -->
    <div
      class="border-olea-olive/20 mt-4 flex w-3/4 items-center justify-center gap-2 border-t pt-4 font-mono text-base"
    >
      <Icon class="mr-2 inline h-5 w-5" name="lucide:globe" />
      <a
        href={hrUrl}
        class={`mobile-link ${lang === 'hr' ? 'text-olea-olive font-bold' : 'hover:text-olea-olive transition-colors opacity-70'}`}
        >HR</a
      >
      <span class="opacity-30">|</span>
      <a
        href={enUrl}
        class={`mobile-link ${lang === 'en' ? 'text-olea-olive font-bold' : 'hover:text-olea-olive transition-colors opacity-70'}`}
        >EN</a
      >
    </div>
  </div>
</header>

<script>
  function setupNavbar() {
    const menuBtn = document.getElementById('menu-toggle-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconMenuOpen = document.getElementById('icon-menu-open');
    const iconMenuClose = document.getElementById('icon-menu-close');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    // Menu toggle logic
    function toggleMenu() {
      if (!mobileMenu || !menuBtn) return;
      const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';

      mobileMenu.classList.toggle('hidden');
      mobileMenu.classList.toggle('flex');
      iconMenuOpen?.classList.toggle('hidden');
      iconMenuClose?.classList.toggle('hidden');

      menuBtn.setAttribute('aria-expanded', (!isExpanded).toString());
    }

    menuBtn?.addEventListener('click', toggleMenu);

    // Close menu when a link is clicked
    mobileLinks.forEach((link) => {
      link.addEventListener('click', () => {
        if (mobileMenu && !mobileMenu.classList.contains('hidden')) {
          toggleMenu();
        }
      });
    });

    // Mobile dropdown toggle helper
    function setupMobileDropdown(btnId, contentId, chevronId) {
      const btn = document.getElementById(btnId);
      const content = document.getElementById(contentId);
      const chevron = document.getElementById(chevronId);

      btn?.addEventListener('click', () => {
        if (!content || !chevron) return;
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';

        content.classList.toggle('hidden');
        content.classList.toggle('flex');
        chevron.classList.toggle('rotate-180');

        btn.setAttribute('aria-expanded', (!isExpanded).toString());
      });
    }

    setupMobileDropdown(
      'mobile-o-projektu-btn',
      'mobile-o-projektu-content',
      'mobile-o-projektu-chevron'
    );
    setupMobileDropdown(
      'mobile-rjesenja-btn',
      'mobile-rjesenja-content',
      'mobile-rjesenja-chevron'
    );
  }

  // Run on page load and on View Transitions page swap
  document.addEventListener('astro:page-load', setupNavbar);

  // Fallback for first load if astro:page-load doesn't fire immediately
  setupNavbar();
</script>
