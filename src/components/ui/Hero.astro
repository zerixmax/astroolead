---
import { Image } from 'astro:assets';
import heroBg from '../../assets/images/olive-hero-bg.webp';
import { useTranslations } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="min-h-[80vh] relative overflow-hidden flex items-center justify-center bg-olea-earth py-24">
  <!-- Static Image Background -->
  <div class="absolute inset-0 z-0 w-full h-full">
    <Image 
      src={heroBg} 
      alt="Olea Digitalis Olive Grove" 
      class="w-full h-full object-cover" 
      loading="eager"
    />
  </div>

  <!-- Tamni overlay sloj -->
  <div class="absolute inset-0 bg-black/60 z-10"></div>

  <!-- Sadržaj Hero sekcije -->
  <div class="relative z-20 text-center px-6 max-w-4xl mx-auto flex flex-col items-center space-y-8 md:space-y-10">
    <h1 class="text-5xl md:text-7xl font-serif text-white leading-tight italic drop-shadow-md">
      {t('hero.title')}
    </h1>
    
    <div class="flex flex-col items-center gap-6 w-full">
      <div class="h-px w-32 bg-white/40"></div>
      <p class="text-xl md:text-2xl font-sans text-olea-sand tracking-wide max-w-2xl mx-auto leading-relaxed">
        {t('hero.subtitle')}
      </p>
      <div class="h-px w-32 bg-white/40"></div>
    </div>

    <!-- Call to Action Gumb -->
    <a 
      href={`/${lang}/#projekt`} 
      class="bg-olea-olive text-white px-8 py-3.5 rounded-full hover:bg-white hover:text-olea-olive transition-all duration-300 font-sans text-lg font-semibold tracking-wider shadow-lg hover:shadow-xl hover:scale-105 active:scale-95"
    >
      {t('hero.cta')}
    </a>
  </div>
</section>
