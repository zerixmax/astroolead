---
import { Image } from 'astro:assets';
import heroBg from '../../assets/images/olive-hero-bg.webp';
import { useTranslations } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  class="bg-olea-earth relative flex min-h-[80vh] items-center justify-center overflow-hidden py-24"
>
  <!-- Static Image Background -->
  <div class="absolute inset-0 z-0 h-full w-full">
    <Image
      src={heroBg}
      alt="Olea Digitalis Olive Grove"
      class="h-full w-full object-cover"
      loading="eager"
    />
  </div>

  <!-- Tamni overlay sloj -->
  <div class="absolute inset-0 z-10 bg-black/60"></div>

  <!-- Sadržaj Hero sekcije -->
  <div
    class="relative z-20 mx-auto flex max-w-4xl flex-col items-center space-y-8 px-6 text-center md:space-y-10"
  >
    <h1
      class="font-serif text-5xl leading-tight text-white italic drop-shadow-md md:text-7xl"
    >
      {t('hero.title')}
    </h1>

    <div class="flex w-full flex-col items-center gap-6">
      <div class="h-px w-32 bg-white/40"></div>
      <p
        class="text-olea-sand mx-auto max-w-2xl font-sans text-xl leading-relaxed tracking-wide md:text-2xl"
      >
        {t('hero.subtitle')}
      </p>
      <div class="h-px w-32 bg-white/40"></div>
    </div>

    <!-- Call to Action Gumb -->
    <a
      href={`/${lang}/#projekt`}
      class="bg-olea-olive hover:text-olea-olive rounded-full px-8 py-3.5 font-sans text-lg font-semibold tracking-wider text-white shadow-lg transition-all duration-300 hover:scale-105 hover:bg-white hover:shadow-xl active:scale-95"
    >
      {t('hero.cta')}
    </a>
  </div>
</section>
