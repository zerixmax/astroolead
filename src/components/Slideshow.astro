---
import { Image } from 'astro:assets';

interface SlideImage {
  src: ImageMetadata | string;
  title: string;
  description?: string;
}

interface Props {
  images: SlideImage[];
}

const { images = [] } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full max-w-6xl mx-auto py-8">
  {images.map((image) => {
    // Determine the high-resolution URL for the lightbox
    const highResUrl = typeof image.src === 'string' ? image.src : image.src.src;
    return (
      <a 
        data-fslightbox="slideshow-gallery" 
        href={highResUrl} 
        class="group relative block rounded-2xl overflow-hidden shadow-lg border border-olea-olive/20 hover:border-olea-olive/60 transition-all duration-300 bg-white cursor-pointer aspect-video flex items-center justify-center p-4"
        aria-label={`Otvori sliku ${image.title}`}
      >
        <Image 
          src={image.src as any} 
          alt={image.title} 
          class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4">
          <h3 class="text-lg font-bold text-white">{image.title}</h3>
          {image.description && <p class="text-sm text-gray-300 line-clamp-2 mt-1">{image.description}</p>}
        </div>
      </a>
    );
  })}
</div>

<script>
  // Initialize fslightbox. The import ensures it gets bundled by Vite.
  import 'fslightbox';
</script>
