---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface SlideImage {
  src: ImageMetadata | string;
  title: string;
  description?: string;
}

interface Props {
  images: SlideImage[];
}

const { images = [] } = Astro.props;
---

<div
  class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-6 py-8 md:grid-cols-3"
>
  {
    images.map((image) => {
      // Determine the high-resolution URL for the lightbox
      const highResUrl =
        typeof image.src === 'string' ? image.src : image.src.src;
      return (
        <a
          data-fslightbox="slideshow-gallery"
          href={highResUrl}
          class="group border-olea-olive/20 hover:border-olea-olive/60 relative block flex aspect-video cursor-pointer items-center justify-center overflow-hidden rounded-2xl border bg-white p-4 shadow-lg transition-all duration-300"
          aria-label={`Otvori sliku ${image.title}`}
        >
          <Image
            src={image.src}
            alt={image.title}
            class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black/80 via-black/20 to-transparent p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <h3 class="text-lg font-bold text-white">{image.title}</h3>
            {image.description && (
              <p class="mt-1 line-clamp-2 text-sm text-gray-300">
                {image.description}
              </p>
            )}
          </div>
        </a>
      );
    })
  }
</div>

<script>
  // Initialize fslightbox. The import ensures it gets bundled by Vite.
  import 'fslightbox';

  declare global {
    interface Window {
      refreshFsLightbox?: () => void;
    }
  }

  function initLightbox() {
    if (typeof window !== 'undefined' && window.refreshFsLightbox) {
      window.refreshFsLightbox();
    }
  }

  // Run on page load and on Astro View Transitions swap
  document.addEventListener('astro:page-load', initLightbox);

  // Also run on DOMContentLoaded just in case
  document.addEventListener('DOMContentLoaded', initLightbox);

  // Initial call
  initLightbox();
</script>
