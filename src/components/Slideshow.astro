---
import { Image } from 'astro:assets';
import { ChevronLeft, ChevronRight } from '@lucide/astro';

// Uvoz tvojih inženjerskih slika
import img1 from '../assets/images/olead-digitalis-astro-202603.webp';
import img2 from '../assets/images/olead-digitalis-astro-202604.webp';
import img3 from '../assets/images/olead-digitalis-astro-202602.webp';
import img4 from '../assets/images/olead-digitalis-astro-202601.webp';
---

<div class="relative group w-full max-w-6xl mx-auto rounded-2xl shadow-2xl overflow-hidden bg-[#1A1A1A] aspect-video border border-olea-olive/20">
  
  <div id="slides-container" class="relative w-full h-full">
    <div class="slide absolute inset-0 transition-opacity duration-500 ease-in-out opacity-100 z-10">
      <Image src={img1} alt="OleaDbot Nacrt 1" class="w-full h-full object-contain" />
    </div>
    <div class="slide absolute inset-0 transition-opacity duration-500 ease-in-out opacity-0 z-0">
      <Image src={img2} alt="OleaDbot Nacrt 2" class="w-full h-full object-contain" />
    </div>
    <div class="slide absolute inset-0 transition-opacity duration-500 ease-in-out opacity-0 z-0">
      <Image src={img3} alt="OleaDbot Nacrt 3" class="w-full h-full object-contain" />
    </div>
    <div class="slide absolute inset-0 transition-opacity duration-500 ease-in-out opacity-0 z-0">
      <Image src={img4} alt="OleaDbot Nacrt 4" class="w-full h-full object-contain" />
    </div>
  </div>

  <button id="btn-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 p-3 bg-black/50 hover:bg-olea-olive text-white rounded-full backdrop-blur-sm transition-all md:opacity-0 md:group-hover:opacity-100 focus:outline-none" aria-label="Prethodna slika">
    <ChevronLeft class="w-8 h-8" />
  </button>
  
  <button id="btn-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 p-3 bg-black/50 hover:bg-olea-olive text-white rounded-full backdrop-blur-sm transition-all md:opacity-0 md:group-hover:opacity-100 focus:outline-none" aria-label="Sljedeća slika">
    <ChevronRight class="w-8 h-8" />
  </button>

  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-20 flex gap-3">
    <div class="dot w-3 h-3 rounded-full bg-white transition-opacity opacity-100"></div>
    <div class="dot w-3 h-3 rounded-full bg-white transition-opacity opacity-40"></div>
    <div class="dot w-3 h-3 rounded-full bg-white transition-opacity opacity-40"></div>
    <div class="dot w-3 h-3 rounded-full bg-white transition-opacity opacity-40"></div>
  </div>
</div>

<script>
  // Čista Vanilla JS logika - Nema "Auto-play" funkcije!
  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.dot');
  const btnPrev = document.getElementById('btn-prev');
  const btnNext = document.getElementById('btn-next');
  let currentIndex = 0;

  function updateSlides(index: number) {
    slides.forEach((slide, i) => {
      if (i === index) {
        slide.classList.replace('opacity-0', 'opacity-100');
        slide.classList.replace('z-0', 'z-10');
        dots[i].classList.replace('opacity-40', 'opacity-100');
      } else {
        slide.classList.replace('opacity-100', 'opacity-0');
        slide.classList.replace('z-10', 'z-0');
        dots[i].classList.replace('opacity-100', 'opacity-40');
      }
    });
  }

  btnNext?.addEventListener('click', () => {
    currentIndex = (currentIndex === slides.length - 1) ? 0 : currentIndex + 1;
    updateSlides(currentIndex);
  });

  btnPrev?.addEventListener('click', () => {
    currentIndex = (currentIndex === 0) ? slides.length - 1 : currentIndex - 1;
    updateSlides(currentIndex);
  });
</script>
